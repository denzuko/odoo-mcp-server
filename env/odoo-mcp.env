# env/odoo-mcp.env — template only
# odoo_mcp_setup.sh generates the live copy at install time.
# Secrets (ODOO_API_KEY) are never set here — inject via environment
# or let the setup script prompt for them.
#
# Install location (service account):
#   ~/.config/containers/systemd/odoo-mcp.env
#
# All values overridable via environment variables at install time:
#   ODOO_URL=https://dapla.net ./odoo_mcp_setup.sh

# ── Odoo connection ──────────────────────────────────────────────────────
ODOO_URL=
ODOO_DB=
ODOO_USER=
# ODOO_API_KEY — generated/injected at install time, never stored in template

# ── Server bind ─────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ── CORS ────────────────────────────────────────────────────────────────
# Comma-separated origins for the HTTP transport.
# For local-only use, restrict to empty or your Claude Desktop origin.
CORS_ORIGINS=https://claude.ai
